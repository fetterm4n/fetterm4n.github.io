{{- $pages := where (where .Site.RegularPages "Section" "blog") "Params.entryType" "blog" -}}
[
{{- range $index, $p := $pages.ByDate.Reverse -}}
  {{- if $index }},{{ end }}
  {
    "title": {{ $p.Title | jsonify }},
    "summary": {{ (or $p.Params.summary ($p.Summary | plainify)) | jsonify }},
    "tags": {{ $p.Params.tags | jsonify }},
    "content": {{ ($p.Plain | htmlUnescape | truncate 12000) | jsonify }},
    "permalink": {{ $p.RelPermalink | jsonify }},
    "date": {{ ($p.Date.Format "2006-01-02") | jsonify }}
  }
{{- end -}}
]
